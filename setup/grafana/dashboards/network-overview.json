{
  "__inputs": [
    {
      "name": "DS_VICTORIALOGS",
      "label": "VictoriaLogs",
      "description": "",
      "type": "datasource",
      "pluginId": "victoriametrics-logs-datasource",
      "pluginName": "VictoriaLogs"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "0.1.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "High-level view of network alerts, top talkers, ports, and protocol distribution from Suricata EVE logs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Alert Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count() by (alert_severity)",
          "legendFormat": "{{alert_severity}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Total Alerts Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count()",
          "legendFormat": "Total Alerts",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Alerts (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | alert_severity:\"critical\" | count()",
          "legendFormat": "Critical",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Critical Alerts (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Top Talkers & Ports",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "count" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "count" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count() by (src_ip) | sort(count desc) | limit(10)",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 10 Source IPs",
      "type": "table"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "gradientMode": "none" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "id": 5,
      "options": {
        "barRadius": 0.03,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count() by (dest_port) | sort(count desc) | limit(10)",
          "legendFormat": "port {{dest_port}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top 10 Destination Ports",
      "type": "barchart"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 10 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "values": ["percent"] }, "pieType": "pie", "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count() by (alert_severity)",
          "legendFormat": "{{alert_severity}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Alert Severity Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 10 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "values": ["percent"] }, "pieType": "donut", "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count() by (proto)",
          "legendFormat": "{{proto}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Protocol Breakdown",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Alert Details",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "id": 8,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | src_ip:~\"$src_ip\"",
          "legendFormat": "",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Alerts",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["security-shallots", "network", "suricata"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | distinct(src_ip)",
        "hide": 0,
        "includeAll": true,
        "label": "Source IP",
        "multi": true,
        "name": "src_ip",
        "options": [],
        "query": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | distinct(src_ip)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | distinct(proto)",
        "hide": 0,
        "includeAll": true,
        "label": "Protocol",
        "multi": true,
        "name": "proto",
        "options": [],
        "query": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | distinct(proto)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Network Overview",
  "uid": "shallots-network-overview",
  "version": 1
}

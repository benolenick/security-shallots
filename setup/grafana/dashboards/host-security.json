{
  "__inputs": [
    {
      "name": "DS_VICTORIALOGS",
      "label": "VictoriaLogs",
      "description": "",
      "type": "datasource",
      "pluginId": "victoriametrics-logs-datasource",
      "pluginName": "VictoriaLogs"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "0.1.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Host-based security: Wazuh file integrity alerts, authentication failures, suspicious processes",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short", "mappings": [] }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"syscheck\" | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "File Integrity Alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }] }, "unit": "short", "mappings": [] }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"authentication_failed\" | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Auth Failures (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short", "mappings": [] }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"promisc\" | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Promiscuous Mode Detected",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short", "mappings": [] }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_level:>=10 | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "High Severity Alerts",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 101,
      "title": "File Integrity Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "modified" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "added" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "deleted" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" },
        "stacking": { "group": "A", "mode": "normal" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"syscheck\" | count() by (syscheck_event)",
          "legendFormat": "{{syscheck_event}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "File Integrity Events Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "id": 6,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "count" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"syscheck\" | count() by (syscheck_path) | sort(count desc) | limit(20)",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Most Changed Files",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 102,
      "title": "Authentication",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 14 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"authentication_failed\" | count()",
          "legendFormat": "Failures",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"authentication_success\" | count()",
          "legendFormat": "Success",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "Authentication Events Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 14 },
      "id": 8,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "count" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:\"authentication_failed\" | count() by (data_dstuser) | sort(count desc) | limit(15)",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top Targeted Users",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 103,
      "title": "Process & Privilege Monitoring",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 9,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"wazuh\"} | json | rule_group:~\"(rootcheck|promisc|exploit|shellshock)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "High-Risk Events (rootcheck, privilege escalation, exploits)",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["security-shallots", "host", "wazuh"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"wazuh\"} | json | distinct(agent_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Agent / Host",
        "multi": true,
        "name": "agent",
        "options": [],
        "query": "_stream:{job=\"wazuh\"} | json | distinct(agent_name)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Host Security",
  "uid": "shallots-host-security",
  "version": 1
}

{
  "__inputs": [
    {
      "name": "DS_VICTORIALOGS",
      "label": "VictoriaLogs",
      "description": "",
      "type": "datasource",
      "pluginId": "victoriametrics-logs-datasource",
      "pluginName": "VictoriaLogs"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "0.1.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "pfSense firewall activity: blocked connections, top source IPs and ports, interface traffic, rule hits",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Firewall Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | pf_action:\"block\" | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Blocked Connections (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | pf_action:\"pass\" | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Allowed Connections (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | pf_action:\"block\" | count() by (pf_src) | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Unique Blocked Sources",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 3, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Log Events (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 101,
      "title": "Block Activity Over Time",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "block" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "pass" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "reject" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | count() by (pf_action)",
          "legendFormat": "{{pf_action}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Blocked Connections Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "values": ["percent"] }, "pieType": "donut", "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | count() by (pf_interface)",
          "legendFormat": "{{pf_interface}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Interface Traffic Breakdown",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 102,
      "title": "Top Blocked Sources & Ports",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "pf_src" }, "properties": [{ "id": "displayName", "value": "Source IP" }] },
          { "matcher": { "id": "byName", "options": "count" }, "properties": [{ "id": "displayName", "value": "Block Count" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 500 }] } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 14 },
      "id": 7,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Block Count" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | pf_action:\"block\" | count() by (pf_src) | sort(count desc) | limit(20)",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top Blocked Source IPs",
      "type": "table"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "gradientMode": "none" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 8, "x": 8, "y": 14 },
      "id": 8,
      "options": {
        "barRadius": 0.03,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "orientation": "horizontal",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | pf_action:\"block\" | count() by (pf_dstport) | sort(count desc) | limit(15)",
          "legendFormat": "port {{pf_dstport}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top Blocked Destination Ports",
      "type": "barchart"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "pf_rulenumber" }, "properties": [{ "id": "displayName", "value": "Rule #" }, { "id": "custom.width", "value": 80 }] },
          { "matcher": { "id": "byName", "options": "pf_action" }, "properties": [{ "id": "displayName", "value": "Action" }] },
          { "matcher": { "id": "byName", "options": "count" }, "properties": [{ "id": "displayName", "value": "Hit Count" }, { "id": "custom.displayMode", "value": "lcd-gauge" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 500 }, { "color": "red", "value": 2000 }] } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 14 },
      "id": 9,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Hit Count" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | count() by (pf_rulenumber, pf_action) | sort(count desc) | limit(25)",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Firewall Rule Hit Counts",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 103,
      "title": "Protocol & State",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 25 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "values": ["percent"] }, "pieType": "pie", "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | count() by (pf_proto)",
          "legendFormat": "{{pf_proto}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Protocol Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 25 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | count() by (pf_interface, pf_direction)",
          "legendFormat": "{{pf_interface}} {{pf_direction}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Interface Traffic Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Recent Firewall Events",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto" } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "id": 12,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"pfsense\"} | json | pf_action:\"block\" | pf_interface:~\"$interface\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Blocked Events",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["security-shallots", "pfsense", "firewall"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"pfsense\"} | json | distinct(pf_interface)",
        "hide": 0,
        "includeAll": true,
        "label": "Interface",
        "multi": true,
        "name": "interface",
        "options": [],
        "query": "_stream:{job=\"pfsense\"} | json | distinct(pf_interface)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"pfsense\"} | json | distinct(pf_action)",
        "hide": 0,
        "includeAll": true,
        "label": "Action",
        "multi": true,
        "name": "action",
        "options": [],
        "query": "_stream:{job=\"pfsense\"} | json | distinct(pf_action)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"pfsense\"} | json | distinct(pf_proto)",
        "hide": 0,
        "includeAll": true,
        "label": "Protocol",
        "multi": true,
        "name": "proto",
        "options": [],
        "query": "_stream:{job=\"pfsense\"} | json | distinct(pf_proto)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "pfSense Firewall",
  "uid": "shallots-pfsense-firewall",
  "version": 1
}

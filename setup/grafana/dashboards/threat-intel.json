{
  "__inputs": [
    {
      "name": "DS_VICTORIALOGS",
      "label": "VictoriaLogs",
      "description": "",
      "type": "datasource",
      "pluginId": "victoriametrics-logs-datasource",
      "pluginName": "VictoriaLogs"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "0.1.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "CrowdSec threat intelligence: blocked IPs, blocklist matches, attack type distribution",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "CrowdSec Decisions",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | count() by (scenario)",
          "legendFormat": "{{scenario}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "CrowdSec Decisions Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Bans (24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "orientation": "auto", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | count() by (value) | count()",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Unique Blocked IPs",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Blocked IPs & Blocklists",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "value" }, "properties": [{ "id": "displayName", "value": "IP Address" }, { "id": "custom.width", "value": 150 }] },
          { "matcher": { "id": "byName", "options": "scenario" }, "properties": [{ "id": "displayName", "value": "Scenario" }] },
          { "matcher": { "id": "byName", "options": "count" }, "properties": [{ "id": "displayName", "value": "Hit Count" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Hit Count" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | count() by (value, scenario) | sort(count desc) | limit(50)",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Blocked IPs",
      "type": "table"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "origin" }, "properties": [{ "id": "displayName", "value": "Blocklist" }] },
          { "matcher": { "id": "byName", "options": "count" }, "properties": [{ "id": "displayName", "value": "Matches" }, { "id": "custom.displayMode", "value": "lcd-gauge" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 1000 }] } }] }
        ]
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "id": 5,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Matches" }] },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | count() by (origin) | sort(count desc)",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Blocklist Matches by Source",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 102,
      "title": "Attack Type Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 21 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] }, "pieType": "donut", "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | count() by (scenario)",
          "legendFormat": "{{scenario}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Attack Types Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 21 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "expr": "_stream:{job=\"suricata\"} | json | event_type:\"alert\" | count() by (alert_category)",
          "legendFormat": "{{alert_category}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Suricata Alert Categories Over Time",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["security-shallots", "threat-intel", "crowdsec"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
        "definition": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | distinct(scenario)",
        "hide": 0,
        "includeAll": true,
        "label": "Scenario",
        "multi": true,
        "name": "scenario",
        "options": [],
        "query": "_stream:{job=\"crowdsec\"} | json | type:\"ban\" | distinct(scenario)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Threat Intelligence",
  "uid": "shallots-threat-intel",
  "version": 1
}

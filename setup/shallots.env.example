# Security Shallots systemd environment
# Copy to /etc/shallots/shallotd.env for a system install, or keep beside the
# repo and point deploy-linux-service at it. Do not commit real API keys.

# Python runtime controls
PYTHONUNBUFFERED=1

# Optional API keys used by config.yaml when it references environment values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=

# Watchdog behavior. The watchdog probes local health and restarts the service
# after SHALLOT_WATCHDOG_MAX_FAILURES consecutive failures.
SHALLOT_HEALTH_URL=https://127.0.0.1:8844/api/health
SHALLOT_SERVICE=shallotd.service
SHALLOT_WATCHDOG_MAX_FAILURES=3
SHALLOT_WATCHDOG_TIMEOUT_S=5

# Backup retention and destination.
SHALLOT_BACKUP_DEST=/var/lib/shallots/backups
SHALLOT_BACKUP_HOURLY=24
SHALLOT_BACKUP_DAILY=14
SHALLOT_BACKUP_WEEKLY=8

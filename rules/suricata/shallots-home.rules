# Security Shallots — Curated Home Lab Rules
# These supplement ET-Open and focus on home network threats.
# SID range: 9000001-9000099

# ── SSH Brute Force ──────────────────────────────────────────
alert ssh any any -> $HOME_NET 22 (msg:"SHALLOTS SSH brute force attempt"; \
    flow:to_server,established; \
    threshold:type both, track by_src, count 5, seconds 120; \
    classtype:attempted-admin; sid:9000001; rev:1;)

# ── RDP Brute Force ──────────────────────────────────────────
alert tcp any any -> $HOME_NET 3389 (msg:"SHALLOTS RDP brute force attempt"; \
    flow:to_server,established; \
    threshold:type both, track by_src, count 5, seconds 120; \
    classtype:attempted-admin; sid:9000002; rev:1;)

# ── DNS over HTTPS (DoH) to known resolvers ──────────────────
alert tls $HOME_NET any -> [1.1.1.1,8.8.8.8,8.8.4.4,9.9.9.9] 443 \
    (msg:"SHALLOTS DNS-over-HTTPS to public resolver"; \
    tls.sni; content:"dns."; startswith; \
    classtype:policy-violation; sid:9000010; rev:1;)

# ── Outbound IRC (common C2 channel) ─────────────────────────
alert tcp $HOME_NET any -> $EXTERNAL_NET [6660:6669,6697,7000] \
    (msg:"SHALLOTS Outbound IRC connection (possible C2)"; \
    flow:to_server,established; \
    classtype:trojan-activity; sid:9000011; rev:1;)

# ── Tor Entry Node Connection ────────────────────────────────
alert tcp $HOME_NET any -> $EXTERNAL_NET [9001,9030] \
    (msg:"SHALLOTS Outbound Tor connection"; \
    flow:to_server,established; \
    classtype:policy-violation; sid:9000012; rev:1;)

# ── Internal Port Scan Detection ─────────────────────────────
alert tcp $HOME_NET any -> $HOME_NET any (msg:"SHALLOTS Internal port scan detected"; \
    flags:S; \
    threshold:type both, track by_src, count 30, seconds 60; \
    classtype:attempted-recon; sid:9000020; rev:1;)

# ── SMB/CIFS Lateral Movement ────────────────────────────────
alert tcp $HOME_NET any -> $HOME_NET 445 (msg:"SHALLOTS SMB connection between workstations"; \
    flow:to_server,established; \
    classtype:attempted-admin; sid:9000021; rev:1;)

# ── WinRM Lateral Movement ───────────────────────────────────
alert tcp $HOME_NET any -> $HOME_NET [5985,5986] (msg:"SHALLOTS WinRM connection (possible lateral movement)"; \
    flow:to_server,established; \
    classtype:attempted-admin; sid:9000022; rev:1;)

# ── LLMNR/NBT-NS (common for Responder attacks) ──────────────
alert udp $HOME_NET any -> 224.0.0.252 5355 (msg:"SHALLOTS LLMNR query (Responder target)"; \
    classtype:attempted-recon; sid:9000030; rev:1;)

# ── Large Outbound Transfer (possible exfil) ─────────────────
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"SHALLOTS Large outbound data transfer"; \
    flow:to_server,established; \
    dsize:>10000; \
    threshold:type both, track by_src, count 100, seconds 60; \
    classtype:bad-unknown; sid:9000040; rev:1;)

# ── Crypto Mining Pool Connection ────────────────────────────
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"SHALLOTS Crypto mining pool connection"; \
    tls.sni; content:"pool."; startswith; \
    classtype:trojan-activity; sid:9000050; rev:1;)

alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"SHALLOTS Crypto mining pool connection (stratum)"; \
    tls.sni; content:"stratum"; \
    classtype:trojan-activity; sid:9000051; rev:1;)

# ── IoT / Smart Home Suspicious Traffic ──────────────────────
alert dns $HOME_NET any -> any any (msg:"SHALLOTS IoT device phoning home to CN TLD"; \
    dns.query; content:".cn"; endswith; \
    classtype:policy-violation; sid:9000060; rev:1;)

# ── DNS Tunneling Detection ──────────────────────────────────
alert dns $HOME_NET any -> any 53 (msg:"SHALLOTS Possible DNS tunneling (long query)"; \
    dns.query; content:"|00|"; offset:50; \
    classtype:trojan-activity; sid:9000070; rev:1;)
